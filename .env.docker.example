# ---------------------------------------------------------------------------
# Variables de entorno para docker-compose.yml / docker-compose.override.yml
#
# Copia este archivo a ".env" en la raíz del repositorio (Docker Compose lo
# carga automáticamente) y ajusta los valores según tu entorno local:
#
#   copy .env.docker.example .env        (Windows)
#   cp .env.docker.example .env          (Linux/Mac)
#
# Nota: este ".env" de la RAÍZ es exclusivo de Docker Compose y es distinto
# de backend/.env y frontend/.env (que siguen usándose para el flujo local
# con XAMPP descrito en el README). No se versiona (ver .gitignore).
#
# Ver: Documentacion/PLAN_DOCKERIZACION_Y_PRUEBAS_E2E_CYPRESS.md (Fase D0/D3).
# ---------------------------------------------------------------------------

# --- Aplicación -------------------------------------------------------------
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
# Genera uno nuevo con: docker compose run --rm backend php artisan key:generate --show
APP_KEY=

# --- Base de datos (contenedor "db", MySQL 8) --------------------------------
# Puerto en el HOST por el que se expone MySQL (3307 por defecto, para no
# chocar con el MySQL nativo de XAMPP que normalmente usa 3306).
DB_FORWARD_PORT=3307
DB_DATABASE=eduwanka
DB_USERNAME=eduwanka
DB_PASSWORD=eduwanka
DB_ROOT_PASSWORD=rootpassword

# --- CORS / Sanctum (deben incluir el origen del frontend) -------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# --- Multi-tenancy (opcional; vacío = modo SaaS local por subdominios) -------
VITE_APP_BASE_DOMAIN=

# --- Correo (en local/demo basta con "log": los correos quedan en storage/logs)
MAIL_MAILER=log

# --- Mercado Pago (opcional; dejar vacío para correr sin pagos en línea) -----
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
