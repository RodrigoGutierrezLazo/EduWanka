# Variables fijas del build de producción (npm run build).
# Vite las aplica por encima de .env — así un build de producción nunca sale
# sin el dominio base (causa del incidente 2026-06-10: eduwanka.net.pe
# mostraba el aula del tenant "eduwanka" en vez de la landing del SaaS).

# El SPA y la API comparten origen en producción.
VITE_API_BASE_URL=

# Dominio raíz real de la plataforma SaaS. Debe coincidir con
# TENANT_BASE_DOMAIN del backend.
VITE_APP_BASE_DOMAIN=eduwanka.net.pe
