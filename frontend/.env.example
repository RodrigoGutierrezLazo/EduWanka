# URL base de la API. Déjalo VACÍO para usar el proxy de desarrollo de Vite
# (las peticiones a /api, /sanctum y /storage se redirigen a VITE_DEV_PROXY).
# En producción, el SPA y la API comparten origen, por lo que también va vacío.
VITE_API_BASE_URL=

# Destino al que el dev server de Vite proxifica /api, /sanctum y /storage
# durante el desarrollo local (el backend Laravel, ver `php artisan serve`).
VITE_DEV_PROXY=http://localhost:8000

# Dominio raíz real de la plataforma SaaS (sin protocolo ni subdominio), ej:
# eduwanka.net.pe. lib/tenant.ts lo usa para distinguir el dominio raíz del
# SaaS (debe mostrar la landing del SaaS, src/pages/Home.tsx) de los
# subdominios de instituciones (ej. colegio-x.eduwanka.net.pe -> landing de
# esa institución, HomeLegacy). Debe coincidir con TENANT_BASE_DOMAIN del
# backend. Necesario porque sufijos de dominio de 2 niveles (.net.pe,
# .com.pe, .co.uk) hacen que contar segmentos del host no sea suficiente.
VITE_APP_BASE_DOMAIN=
