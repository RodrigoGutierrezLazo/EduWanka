# ------------------------------------------------------------------------------
# CONFIGURACIÓN DE ENTORNO DE PRODUCCIÓN (EduWanka SaaS)
# ------------------------------------------------------------------------------
# Copia este archivo como '.env' en tu servidor de producción Linux VPS
# e introduce los datos reales de tu dominio y base de datos.

APP_NAME="EduWanka Aula Virtual"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://eduwanka.pe
APP_KEY=base64:GENERATE_WITH_KEY_GENERATE_ON_SERVER

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eduwanka_production
DB_USERNAME=eduwanka_db_user
DB_PASSWORD=ESCRIBE_AQUI_UN_PASSWORD_MUY_SEGURO_Y_LARGO
# Para producción con MariaDB/MySQL en Linux, usar la intercalación recomendada
DB_COLLATION=utf8mb4_unicode_ci

# Aislamiento de Sesiones en SaaS
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
# Importante: El punto inicial permite que las cookies de sesión se compartan
# entre el dominio principal (eduwanka.pe) y todos los subdominios de inquilinos (*.eduwanka.pe)
SESSION_DOMAIN=.eduwanka.pe
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ------------------------------------------------------------------------------
# CONFIGURACIÓN DE CORREO ELECTRÓNICO (SMTP)
# ------------------------------------------------------------------------------
# Reemplaza estas credenciales cuando tengas tu correo institucional real.
# Hostinger SMTP suele usar el puerto 465 (SSL) o 587 (TLS).
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=correo-real@tuservidor.com
MAIL_PASSWORD=escribe-aqui-tu-password-smtp-real
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=correo-real@tuservidor.com
MAIL_FROM_NAME="EduWanka Aula Virtual"

# ------------------------------------------------------------------------------
# PASARELA DE PAGOS - MERCADO PAGO (Producción)
# ------------------------------------------------------------------------------
# Inserta tus credenciales de producción de Mercado Pago aquí.
# Para pruebas, puedes usar tus credenciales de Sandbox (las que empiezan por TEST-).
MERCADOPAGO_PUBLIC_KEY=APP_USR-tu-public-key-real
MERCADOPAGO_ACCESS_TOKEN=APP_USR-tu-access-token-real

# ------------------------------------------------------------------------------
# SEGURIDAD Y DOMINIOS PERMITIDOS (CORS / SANCTUM)
# ------------------------------------------------------------------------------
# Configura los dominios que la API aceptará para CORS y autenticación stateful de Sanctum.
CORS_ALLOWED_ORIGINS=https://eduwanka.pe,https://*.eduwanka.pe
SANCTUM_STATEFUL_DOMAINS=eduwanka.pe,*.eduwanka.pe
VITE_APP_NAME="${APP_NAME}"
